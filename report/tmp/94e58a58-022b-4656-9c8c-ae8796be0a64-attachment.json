"{\"code\":200,\"msg\":\"success\",\"data\":[{\"id\":\"2038495890659663874\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"客户洞察与倾听能力\",\"type\":\"客户洞察与倾听能力\",\"weight\":25.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"深入挖掘顾客多层次需求，识别潜在痛点\\\"><br>          <关键词>您除了...还关心什么</关键词><br>          <关键词>您提到...是否还有...</关键词><br>          <关键词>您最在意的是...</关键词><br>        </等级><等级 分值=\\\"9-10\\\" 标准=\\\"主动引导式提问，问题层层递进，引导顾客表达深层需求\\\"><br>          <关键词>出现3次以上开放性问题</关键词><br>       \",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"基本挖掘顾客表面需求，了解主要痛点\\\"><br>          <关键词>您的主要困扰是...</关键词><br>          <关键词>您想改善的是...</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"有基本提问，但缺乏系统性和深度\\\"><br>          <关键词>出现1-2次开放性问题，多为封闭式问题</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"有基本复述，但不全面或不精准\\\"><br> \",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"仅了解顾客明确表达的需求，缺乏深入挖掘\\\"><br>          <关键词>您想做什么项目</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"几乎不提问，以自我介绍或产品介绍为主\\\"><br>          <关键词>无主动提问</关键词><br>          <关键词>您想了解什么项目</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"无复述或总结，对客户表达的需求无确认\\\"><br>          \",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"未能识别顾客需求，对顾客表达的痛点无回应\\\"><br>          <关键词>无相关提问，直接推销产品</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"完全没有提问，全程由销售顾问单向输出\\\"><br>          <关键词>对话中没有任何针对客户需求的提问</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"频繁打断客户，忽视客户表达的需求\\\"><br>          <关键词>客户未说完就被打断</关键\"},{\"id\":\"2038495890663858177\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"专业性与说服力\",\"type\":\"专业性与说服力\",\"weight\":20.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"精通产品原理、成分、适应症、禁忌症，能对比多种方案优劣\\\"><br>          <关键词>适用范围</关键词><br>          <关键词>核心成分</关键词><br>          <关键词>作用层次</关键词><br>          <关键词>作用机制</关键词><br>          <关键词>分子量</关键词><br>          <关键词>禁忌症</关键词><br>          <关键词>代谢周期</关键词><br>   \",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"了解基本产品知识，能解释主要原理和效果\\\"><br>          <关键词>填充原理</关键词><br>          <关键词>提升原理</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"基本提及产品价值，但缺乏系统性阐述\\\"><br>          <关键词>效果好</关键词><br>          <关键词>值得</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"有基本案例分享，但不够个性化或生动\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"知识片面，仅能简单介绍产品名称和效果\\\"><br>          <关键词>这个产品很好</关键词><br>          <关键词>效果很明显</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"几乎不提及产品价值，仅关注价格或促销\\\"><br>          <关键词>优惠</关键词><br>          <关键词>便宜</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"无案例分享，表达呆板，缺乏感染\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"知识严重不足，无法回答客户基本疑问\\\"><br>          <关键词>这个我不太清楚</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"完全没有价值感营造，纯粹以价格为导向\\\"><br>          <关键词>只谈价格，无任何价值阐述</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"表达混乱，无法让客户理解产品特点\\\"><br>          <关键词>语言组织混乱，客户多次表示困惑或要求重复解释</关\"},{\"id\":\"2038495890668052481\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"成交引导与执行落地\",\"type\":\"成交引导与执行落地\",\"weight\":15.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"明确给出下一步行动建议，并提供多种选择\\\"><br>          <关键词>我建议您先...</关键词><br>          <关键词>您可以选择...或者...</关键词><br>          <关键词>下一步我们可以...</关键词><br>        </等级><等级 分值=\\\"9-10\\\" 标准=\\\"灵活运用促销方案，针对客户需求定制优惠\\\"><br>          <关键词>针对您的情况，我们有...特别方案</关键词><br>        \",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"有基本行动建议，但不够具体或缺乏选择\\\"><br>          <关键词>您可以考虑做这个项目</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"基本介绍促销方案，但缺乏针对性\\\"><br>          <关键词>我们现在有活动</关键词><br>          <关键词>这个月优惠</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"有基本跟进，但缺乏针对性解决方案\\\"><br>          <关键词\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"无明确行动建议，结束对话模糊不清\\\"><br>          <关键词>无相关引导语，对话结束无明确方向</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"几乎不提及促销方案，或方案与客户需求不匹配\\\"><br>          <关键词>无促销信息，或仅在客户询问后被动提及</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"几乎无跟进，客户表示犹豫后立即结束对话\\\"><br>          <关键词>好的，那您\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"完全没有行动引导，客户不知道接下来该做什么\\\"><br>          <关键词>对话结束时客户仍在询问\\\"我现在应该怎么做\\\"</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"促销方案混乱或误导，引起客户反感\\\"><br>          <关键词>促销条件含糊不清，客户多次询问细节或表示怀疑</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"对犹豫客户表现出明显不耐烦或放弃态度\\\"><br>          <关\"},{\"id\":\"2038495890676441090\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"情绪引导与信任建立\",\"type\":\"情绪引导与信任建立\",\"weight\":15.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"全面强调机构资质、医生背景、真实案例和安全保障\\\"><br>          <关键词>我们机构获得...认证</关键词><br>          <关键词>我们的医生有...年经验</关键词><br>          <关键词>这是真实客户的前后对比</关键词><br>        </等级><等级 分值=\\\"9-10\\\" 标准=\\\"全程保持专业冷静，语气平稳，不急不躁\\\"><br>          <关键词>语速适中，无明显情绪波动，即使面对质疑也保持专业态度</关\",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"基本提及机构优势和安全保障，但不够全面\\\"><br>          <关键词>我们是正规机构</关键词><br>          <关键词>医生很专业</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"基本情绪稳定，但在特定情况下有轻微波动\\\"><br>          <关键词>大部分时间情绪稳定，但在谈及价格或面对质疑时语气有变化</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"基本识别明显情绪，有一定共情\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"几乎不提及机构资质和安全保障\\\"><br>          <关键词>无相关信任建立语句，或仅在客户质疑后被动回应</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"情绪控制不佳，出现明显急躁、不耐烦或过度热情\\\"><br>          <关键词>出现打断客户、语速过快、重复催促等情绪失控表现</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"几乎不识别客户情绪，缺乏共情回应\\\"><br>          <关键\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"回避安全问题，或提供虚假/夸大的机构信息\\\"><br>          <关键词>客户询问安全问题时转移话题，或夸大机构资质</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"情绪完全失控，对客户态度恶劣或情绪化\\\"><br>          <关键词>出现讽刺、挖苦客户或明显情绪化言论</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"完全忽视或误判客户情绪，引发客户负面反应\\\"><br>          <关键词\"},{\"id\":\"2038495890680635393\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"信息传达与表达力\",\"type\":\"信息传达与表达力\",\"weight\":10.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"表达有明确逻辑结构，先需求后方案，层次分明\\\"><br>          <关键词>首先...其次...最后...</关键词><br>          <关键词>基于您的需求...我们的方案是...</关键词><br>        </等级><等级 分值=\\\"9-10\\\" 标准=\\\"全面准确传达项目名称、步骤、周期、效果和注意事项\\\"><br>          <关键词>项目名称</关键词><br>          <关键词>操作步骤</关键词><br>        \",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"基本逻辑清晰，但结构不够严谨\\\"><br>          <关键词>有一定逻辑，但偶有跳跃，需求和方案衔接不够紧密</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"基本传达主要信息，但不够全面\\\"><br>          <关键词>提及主要信息如项目名称、效果，但缺少恢复周期或注意事项等</关键词><br>        </等级><等级 分值=\\\"7-8\\\" 标准=\\\"有基本转化能力，但部分术语解释不够通俗\\\"><br>          <关\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"表达混乱，缺乏逻辑，需求和方案割裂\\\"><br>          <关键词>话题频繁跳转，无明确结构，客户需多次询问才能理解</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"信息传达不足，关键点遗漏\\\"><br>          <关键词>仅简单提及项目名称和价格，其他关键信息缺失</关键词><br>        </等级><等级 分值=\\\"4-6\\\" 标准=\\\"几乎不转化专业术语，大量使用客户无法理解的词汇\\\"><br>          <关键\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"语言组织极度混乱，客户完全无法理解\\\"><br>          <关键词>表达前后矛盾，结构混乱，客户多次表示听不懂</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"产品信息严重不足或错误，误导客户\\\"><br>          <关键词>提供错误的产品信息，或对关键信息完全不提及</关键词><br>        </等级><等级 分值=\\\"0-3\\\" 标准=\\\"完全使用专业术语，客户无法理解任何产品信息\\\"><br>          <关键词\"},{\"id\":\"2038495890684829697\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"术语转化能力\",\"type\":\"信息传达与表达力\",\"weight\":5.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"精通将专业术语转化为通俗易懂的表达，使用生动比喻\\\">\\n          <关键词>这就像...一样</关键词>\\n          <关键词>简单来说就是...</关键词>\\n          <关键词>您可以理解为...</关键词>\\n        </等级>\",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"有基本转化能力，但部分术语解释不够通俗\\\">\\n          <关键词>尝试解释专业术语，但仍使用部分客户难以理解的词汇</关键词>\\n        </等级>\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"几乎不转化专业术语，大量使用客户无法理解的词汇\\\">\\n          <关键词>频繁使用专业术语而不解释，或解释后客户仍表示困惑</关键词>\\n        </等级>\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"完全使用专业术语，客户无法理解任何产品信息\\\">\\n          <关键词>全程使用医学术语，客户多次表示听不懂</关键词>\\n        </等级>\"},{\"id\":\"2038495890684829698\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"产品说明完整度\",\"type\":\"信息传达与表达力\",\"weight\":5.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"全面准确传达项目名称、步骤、周期、效果和注意事项\\\">\\n          <关键词>项目名称</关键词>\\n          <关键词>操作步骤</关键词>\\n          <关键词>恢复周期</关键词>\\n          <关键词>预期效果</关键词>\\n          <关键词>注意事项</关键词>\\n        </等级>\",\"classStandardB\":\"<等级 分值=\\\"7-8\\\" 标准=\\\"基本传达主要信息，但不够全面\\\">\\n          <关键词>提及主要信息如项目名称、效果，但缺少恢复周期或注意事项等</关键词>\\n        </等级>\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"信息传达不足，关键点遗漏\\\">\\n          <关键词>仅简单提及项目名称和价格，其他关键信息缺失</关键词>\\n        </等级>\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"产品信息严重不足或错误，误导客户\\\">\\n          <关键词>提供错误的产品信息，或对关键信息完全不提及</关键词>\\n        </等级>\"},{\"id\":\"2038495890689024001\",\"consultationEvaluateId\":\"2038495890286370817\",\"name\":\"自身情绪控制\",\"type\":\"情绪引导与信任建立\",\"weight\":5.0,\"classStandardA\":\"<等级 分值=\\\"9-10\\\" 标准=\\\"全程保持专业冷静，语气平稳，不急不躁\\\">\\n          <关键词>语速适中，无明显情绪波动，即使面对质疑也保持专业态度</关键词>\\n        </等级>\",\"classStandardB\":\" <等级 分值=\\\"7-8\\\" 标准=\\\"基本情绪稳定，但在特定情况下有轻微波动\\\">\\n          <关键词>大部分时间情绪稳定，但在谈及价格或面对质疑时语气有变化</关键词>\\n        </等级>\",\"classStandardC\":\"<等级 分值=\\\"4-6\\\" 标准=\\\"情绪控制不佳，出现明显急躁、不耐烦或过度热情\\\">\\n          <关键词>出现打断客户、语速过快、重复催促等情绪失控表现</关键词>\\n        </等级>\",\"classStandardD\":\"<等级 分值=\\\"0-3\\\" 标准=\\\"情绪完全失控，对客户态度恶劣或情绪化\\\">\\n          <关键词>出现讽刺、挖苦客户或明显情绪化言论</关键词>\\n        </等级>\"}]}"